@model LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - Leave Management</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(to right, #4e73df, #1cc88a);
            height: 100vh;
        }

        .login-card {
            border-radius: 15px;
        }
    </style>
</head>

<body class="d-flex align-items-center justify-content-center">

    <div class="card shadow-lg p-4 login-card" style="width: 400px;">
        <h3 class="text-center mb-4">Login</h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        <form action="@Url.Action("Login","Auth")" method="post">

            <div class="mb-3">
                <label>Email</label>
                <input type="text" name="Email"
                       value="@Model?.Email"
                       class="form-control" />
                <span class="text-danger">
                    @Html.ValidationMessage("Email")
                </span>
            </div>

            <div class="mb-3">
                <label>Password</label>
                <input type="password" name="Password"
                       class="form-control" />
                <span class="text-danger">
                    @Html.ValidationMessage("Password")
                </span>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Login
            </button>
        </form>

        <div class="text-center mt-3 text-muted fs-8">
            Admin: admin@example.com / admin123 <br />
            Employee: employee@example.com / emp123
        </div>
    </div>

</body>
</html>