@model List<LeaveRequest>
@{
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="container-fluid">

    <h3 class="text-center fw-bold mb-4">Leave Requests</h3>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle text-center table-bordered" style="border-radius:20px;">
                    <thead class="table-secondary">
                        <tr>
                            <th>From Date</th>
                            <th>To Date</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th>Applied On</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var leave in Model)
                            {
                                <tr>
                                    <td>@leave.FromDate.ToString("dd MMM yyyy")</td>
                                    <td>@leave.ToDate.ToString("dd MMM yyyy")</td>
                                    <td class="text-start">@leave.Reason</td>
                                    <td>
                                        @if (leave.Status == "Approved")
                                        {
                                            <span class="badge bg-success px-3 py-1">Approved</span>
                                        }
                                        else if (leave.Status == "Rejected")
                                        {
                                            <span class="badge bg-danger px-3 py-1">Rejected</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark px-3 p1-2">Pending</span>
                                        }
                                    </td>
                                    <td>@leave.CreatedDate.ToString("dd MMM yyyy")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-muted py-4">
                                    No leave requests found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>