@model List<LeaveSummaryViewModel>
@{
    ViewData["Title"] = "Leave Requests";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0 text-center">Leave Requests</h3>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle text-center table-bordered">
                    <thead class="table-secondary">
                        <tr>
                            <th>Employee</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Status</th>
                            <th>Applied On</th>
                            <th width="200">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var leave in Model)
                            {
                                <tr>
                                    <td>@leave.EmployeeName</td>
                                    <td>@leave.FromDate.ToShortDateString()</td>
                                    <td>@leave.ToDate.ToShortDateString()</td>

                                    <td>
                                        @if (leave.Status == "Approved")
                                        {
                                            <span class="badge bg-success px-3 py-1">
                                                Approved
                                            </span>
                                        }
                                        else if (leave.Status == "Rejected")
                                        {
                                            <span class="badge bg-danger px-3 py-1">
                                                Rejected
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-1">
                                                Pending
                                            </span>
                                        }
                                    </td>

                                    <td>@leave.CreatedDate.ToShortDateString()</td>

                                    <td>
                                        @if (leave.Status == "Pending")
                                        {
                                            <a href="@Url.Action("UpdateLeave", "Admin",new { id = leave.LeaveId, status = "Approved" })"class="btn btn-sm btn-success me-2"onclick="return confirm('Approve this leave request?');">
                                            <i class="bi bi-check-circle"></i>
                                        </a>

                                            <a href="@Url.Action("UpdateLeave", "Admin",new { id = leave.LeaveId, status = "Rejected" })"class="btn btn-sm btn-danger"onclick="return confirm('Reject this leave request?');">
                                            <i class="bi bi-x-circle"></i>
                                        </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No Action</span>
                                        }
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-muted py-4">
                                    No leave requests found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>

