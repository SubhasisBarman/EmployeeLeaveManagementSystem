@model List<Employee>
@{
    ViewData["Title"] = "Employees";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">Employees</h3>

        <a href="@Url.Action("AddEditEmployee", "Admin")"
           class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Employee
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle text-center table-bordered">
                    <thead class="table-secondary">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Total Leaves</th>
                            <th>Status</th>
                            <th width="180">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var emp in Model)
                            {
                                <tr>
                                    <td>@emp.FullName</td>
                                    <td>@emp.Email</td>
                                    <td>@emp.Department</td>
                                    <td>@emp.TotalLeaves</td>

                                    <td>
                                        @if (emp.IsActive)
                                        {
                                            <span class="badge bg-success px-3 py-1">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger px-3 py-1">Inactive</span>
                                        }
                                    </td>

                                    <td>
                                        <a href="@Url.Action("AddEditEmployee", "Admin", new { id = emp.EmployeeId })" class="btn btn-sm  me-1">
                                            <i class="bi bi-pencil-square text-warning fs-5"></i>
                                        </a>

                                        <a href="@Url.Action("Deactivate", "Admin", new { id = emp.EmployeeId })" class="btn btn-sm" onclick="return confirm('Are you sure you want to deactivate this employee?');">
                                            <i class="bi bi-person-x text-danger fs-5"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-muted py-4">
                                    No employees found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>

<style>
    .card {
        border-radius: 15px;
    }

    .table th {
        font-weight: 600;
    }

    .btn {
        border-radius: 8px;
    }
</style>